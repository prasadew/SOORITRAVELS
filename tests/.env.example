# Test Environment Configuration
# Copy this file to .env and fill in the values

# Application URLs
BASE_URL=http://localhost/SOORITRAVELS
ADMIN_URL=http://localhost/SOORITRAVELS/admin

# Test User Credentials (Firebase)
TEST_USER_EMAIL=testuser@sooritravels.com
TEST_USER_PASSWORD=Test@12345
